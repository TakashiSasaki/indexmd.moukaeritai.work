{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Directory": {
      "title": "Directory",
      "description": "Google Drive scanned directory state",
      "type": "object",
      "properties": {
        "drive_id": { "type": "string" },
        "path": { "type": "string" },
        "depth": { "type": "integer" },
        "sync_status": { "type": "string" },
        "index_status": { "type": "string" },
        "last_traversed_at": { "type": "string" },
        "last_updated_at": { "type": "string" },
        "parent_id": { "type": "string" },
        "ai_summary": { "type": "string" }
      },
      "required": ["drive_id", "path", "depth", "sync_status", "index_status"]
    },
    "SyncState": {
      "title": "SyncState",
      "description": "State tracking for incremental Drive traverse",
      "type": "object",
      "properties": {
        "nextPageToken": { "type": "string" },
        "sync_status": { "type": "string" },
        "last_traversed_at": { "type": "string" }
      },
      "required": ["sync_status"]
    },
    "Log": {
      "title": "Log",
      "description": "App log logs",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "level": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["timestamp", "level", "message"]
    },
    "FileSummaryMetadata": {
      "title": "FileSummaryMetadata",
      "description": "Durable structured summary and metadata for a Drive file",
      "type": "object",
      "properties": {
        "fileId": { "type": "string" },
        "fileName": { "type": "string" },
        "mimeType": { "type": "string" },
        "modifiedTime": { "type": "string" },
        "schemaVersion": { "type": "string" },
        "promptVersion": { "type": "string" },
        "systemInstructionVersion": { "type": "string" },
        "model": { "type": "string" },
        "outputMode": { "type": "string" },
        "summary": { "type": "string" },
        "structured": { "type": "object" },
        "validationErrors": { "type": "array" },
        "parseSuccess": { "type": "boolean" },
        "validationSuccess": { "type": "boolean" },
        "generatedAt": { "type": "string" },
        "source": { "type": "string" },
        "cacheKey": { "type": "string" }
      },
      "required": ["fileId", "schemaVersion", "promptVersion", "systemInstructionVersion", "model", "outputMode", "summary", "structured", "parseSuccess", "validationSuccess", "generatedAt", "source"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User specific meta"
    },
    "/users/{userId}/directories/{directoryId}": {
      "schema": "Directory",
      "description": "Directories indexed for this user"
    },
    "/users/{userId}/state/{stateId}": {
      "schema": "SyncState",
      "description": "Traversing tracking state"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "Log",
      "description": "Execution log collection"
    },
    "/users/{userId}/file_summaries/{fileId}": {
      "schema": "FileSummaryMetadata",
      "description": "AI-generated structured summaries of Google Drive files"
    }
  }
}
